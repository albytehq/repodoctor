{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@repodoctor/core/*": ["core/*"],
      "@repodoctor/config/*": ["config/*"],
      "@repodoctor/cli/*": ["cli/*"],
      "@repodoctor/logger/*": ["logger/*"],
      "@repodoctor/errors/*": ["errors/*"],
      "@repodoctor/infrastructure/*": ["infrastructure/*"],
      "@repodoctor/utils/*": ["utils/*"],
      "@repodoctor/discovery/*": ["discovery/*"],
      "@repodoctor/scanner/*": ["scanner/*"],
      "@repodoctor/analyzer/*": ["analyzer/*"],
      "@repodoctor/health/*": ["health/*"],
      "@repodoctor/treatment/*": ["treatment/*"],
      "@repodoctor/reporter/*": ["reporter/*"],
      "@repodoctor/cache/*": ["cache/*"],
      "@repodoctor/plugins/*": ["plugins/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
